<div class="space-y-8">
  <% @support_requests.each do |support_request| %>

    <div class="bg-white shadow rounded-lg p-6 border">

      <div class="mb-4">
        <h2 class="text-xl font-bold">
          <%= support_request.subject %>
        </h2>

        <p class="text-sm text-gray-500">
          <%= support_request.created_at.to_formatted_s(:long) %>
        </p>

        <p class="mt-1">
          From:
          <code class="bg-gray-100 px-2 py-1 rounded">
            <%= support_request.email %>
          </code>
        </p>
      </div>

      <div class="bg-gray-50 p-4 rounded border-l-4 border-blue-500">
        <p class="whitespace-pre-wrap">
          <%= support_request.message %>
        </p>
      </div>

      <% if support_request.order %>
        <div class="mt-6">
          <h3 class="text-lg font-semibold mb-3">
            Related Order
          </h3>

          <dl class="grid grid-cols-2 gap-y-2">
            <dt class="font-medium">Name</dt>
            <dd><%= support_request.order.name %></dd>

            <dt class="font-medium">Email</dt>
            <dd><%= support_request.order.email %></dd>

            <dt class="font-medium">Address</dt>
            <dd><%= support_request.order.address %></dd>

            <dt class="font-medium">Pay Type</dt>
            <dd><%= support_request.order.pay_type %></dd>
          </dl>

          <h4 class="font-medium mt-4 mb-2">
            Items Ordered
          </h4>

          <ul class="list-disc ml-6">
            <% support_request.order.line_items.each do |line_item| %>
              <li>
                <%= line_item.product.title %>
                —
                <%= number_to_currency(line_item.product.price) %>
              </li>
            <% end %>
          </ul>
        </div>

      <% else %>

        <div class="mt-4 text-amber-700 bg-amber-50 p-3 rounded">
          No associated order found.
        </div>

      <% end %>

      <% if support_request.response.blank? %>

        <div class="mt-6">
          <%= form_with(
                model: support_request,
                local: true,
                class: "space-y-4"
              ) do |form| %>

            <div>
              <%= form.label :response,
                    "Write Response",
                    class: "block font-medium mb-2" %>

              <%= form.rich_textarea :response,
                    id: :support_request_response %>
            </div>

            <%= form.submit "Send Response",
                  class: "bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded" %>

          <% end %>
        </div>

      <% else %>

        <div class="mt-6">
          <h3 class="text-lg font-semibold mb-2">
            Our Response
          </h3>

          <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
            <%= support_request.response %>
          </div>
        </div>

      <% end %>

    </div>

  <% end %>
</div>
