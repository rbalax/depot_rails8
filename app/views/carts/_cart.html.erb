<div id="<%= dom_id cart %>">
  <h2 class="font-bold text-lg mb-3"><%= t('.title') %></h2>

  <div>
    <%= render cart.line_items %>
  </div>

  <div class="flex justify-end mt-6">
    <div class="text-right font-bold border-t-2 border-black pt-2">
      Total: <%= number_to_currency(cart.total_price) %>
    </div>
  </div>

  <div class="flex items-center space-x-4 mt-8">
    <%= button_to t('.empty'), cart, method: :delete,
      class: 'rounded-lg py-1 px-2 text-white bg-red-600 hover:bg-red-700 transition-colors duration-200' %>

    <%= button_to t('.checkout'), new_order_path, method: :get,
      class: 'rounded-lg py-1 px-2 text-white bg-green-600 hover:bg-green-700 transition-colors duration-200' %>


  </div>
</div>
